{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Load Rift",
  "version": "0.2.3",
  "identifier": "dev.loadrift.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run install:k6 && npm run dev",
    "beforeBuildCommand": "npm run install:k6 && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Load Rift",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "object-src": "'none'"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:5173 ipc: http://ipc.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:5173 ws://localhost:5173",
        "img-src": "'self' asset: http://asset.localhost data: blob: http://localhost:5173",
        "style-src": "'self' 'unsafe-inline' http://localhost:5173",
        "font-src": "'self' data: http://localhost:5173",
        "script-src": "'self' 'unsafe-eval' http://localhost:5173",
        "object-src": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright (c) 2026 Douwe de Vries",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "resources": {
      "bin/": "bin/",
      "../LICENSE": "licenses/LICENSE",
      "../THIRD_PARTY_LICENSES.md": "licenses/THIRD_PARTY_LICENSES.md",
      "../licenses/AGPL-3.0.txt": "licenses/AGPL-3.0.txt"
    },
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/doc/loadrift/LICENSE": "../LICENSE",
          "/usr/share/doc/loadrift/THIRD_PARTY_LICENSES.md": "../THIRD_PARTY_LICENSES.md",
          "/usr/share/doc/loadrift/AGPL-3.0.txt": "../licenses/AGPL-3.0.txt",
          "/usr/share/doc/loadrift/README.md": "../README.md"
        }
      },
      "deb": {
        "files": {
          "/usr/share/doc/loadrift/LICENSE": "../LICENSE",
          "/usr/share/doc/loadrift/THIRD_PARTY_LICENSES.md": "../THIRD_PARTY_LICENSES.md",
          "/usr/share/doc/loadrift/AGPL-3.0.txt": "../licenses/AGPL-3.0.txt",
          "/usr/share/doc/loadrift/README.md": "../README.md"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/doc/loadrift/LICENSE": "../LICENSE",
          "/usr/share/doc/loadrift/THIRD_PARTY_LICENSES.md": "../THIRD_PARTY_LICENSES.md",
          "/usr/share/doc/loadrift/AGPL-3.0.txt": "../licenses/AGPL-3.0.txt",
          "/usr/share/doc/loadrift/README.md": "../README.md"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
